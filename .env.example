# Copy this file to ".env" (next to the executable) and fill in real values.
# NEVER commit the real .env. These secrets are obfuscation, not strong security.

# --- Encrypted inventory Excel passwords ---
# Excel "password to open" (read-only access / decrypts the file)
EXCEL_READ_PASSWORD=

# Excel "password to modify" (read-write access / required to save changes)
EXCEL_WRITE_PASSWORD=

# --- User store ---
# Fernet key used to encrypt users.dat. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
USER_STORE_KEY=

# --- Paths & logging ---
# Path to the active inventory .xlsx. If omitted, defaults to a file next to the executable.
INVENTORY_FILE=

# Logging verbosity: DEBUG | INFO | WARNING | ERROR (default INFO)
LOG_LEVEL=INFO
